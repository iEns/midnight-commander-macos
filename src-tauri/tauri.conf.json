{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Midnight Commander",
  "version": "1.0.0",
  "identifier": "com.local.midnight-commander",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "mc-main",
        "title": "Midnight Commander",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src blob: data: filesystem: ws: wss: http: https: tauri: 'unsafe-eval' 'unsafe-inline' 'self' img-src: 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "category": "Utility",
    "shortDescription": "Midnight Commander terminal host",
    "longDescription": "Hosts the real mc binary in an embedded terminal with multi-window support.",
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}